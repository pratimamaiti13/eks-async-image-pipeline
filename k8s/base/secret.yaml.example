# Day 7-10: copy this to secret.yaml (gitignored), fill in real values from
# terraform output, kubectl apply -f secret.yaml. Never commit the filled-in version.

apiVersion: v1
kind: Secret
metadata:
  name: imgproc-db-credentials
  namespace: imgproc
type: Opaque
stringData:
  DB_HOST: "REPLACE_ME"
  DB_NAME: "REPLACE_ME"
  DB_USER: "REPLACE_ME"
  DB_PASSWORD: "REPLACE_ME"
